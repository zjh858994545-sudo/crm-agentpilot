# Shared
APP_ENV=local
AGENTPILOT_APP_PHASE=ready

# Backend
BACKEND_PORT=18080
FRONTEND_PORT=15173
SPRING_PROFILES_ACTIVE=local
AGENTPILOT_LOG_LEVEL=INFO
AGENTPILOT_SQL_LOG_LEVEL=WARN

# PostgreSQL + pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentpilot
POSTGRES_USER=agentpilot
POSTGRES_PASSWORD=agentpilot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
# local/permissive: no token required, useful for local development
# strict: every business API requires X-AgentPilot-Token
AGENTPILOT_SECURITY_MODE=permissive

# Optional local compatibility token. Prefer database RBAC tokens in agentpilot_user for real use.
AGENTPILOT_API_TOKEN=
AGENTPILOT_DEMO_USER_ID=1
AGENTPILOT_DEMO_SALES_REP_ID=1
AGENTPILOT_SEED_USERS_ENABLED=true

# Built-in seed RBAC tokens for local product walkthrough:
# sales:   agentpilot-sales-1
# manager: agentpilot-manager
# admin:   agentpilot-admin
# Set AGENTPILOT_SEED_USERS_ENABLED=false before a real deployment and provision your own RBAC users/tokens.

# Rate limit
AGENTPILOT_RATE_LIMIT_ENABLED=true
AGENTPILOT_RATE_LIMIT_BACKEND=auto
AGENTPILOT_RATE_LIMIT_DEFAULT_CAPACITY=300
AGENTPILOT_RATE_LIMIT_DEFAULT_REFILL_PER_MINUTE=300
AGENTPILOT_RATE_LIMIT_AGENT_CAPACITY=60
AGENTPILOT_RATE_LIMIT_AGENT_REFILL_PER_MINUTE=60
AGENTPILOT_RATE_LIMIT_MODEL_CAPACITY=30
AGENTPILOT_RATE_LIMIT_MODEL_REFILL_PER_MINUTE=30

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AGENT_EVENTS_KAFKA_ENABLED=false
AGENT_RUN_EVENTS_TOPIC=agent-run-events
AGENT_TOOL_CALL_EVENTS_TOPIC=agent-tool-call-events
CRM_TASK_EVENTS_TOPIC=crm-task-events

# Model provider, keep mock for local development and tests
AGENT_MODEL_PROVIDER=mock
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_CHAT_MODEL=qwen3.6-flash
OPENAI_COMPATIBLE_TEMPERATURE=0.2

# Embedding provider. For Alibaba Bailian DashScope compatible mode:
# OPENAI_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AGENT_MODEL_PROVIDER=openai-compatible
# AGENT_EMBEDDING_PROVIDER=openai-compatible
AGENT_EMBEDDING_PROVIDER=mock
OPENAI_COMPATIBLE_EMBEDDING_BASE_URL=
OPENAI_COMPATIBLE_EMBEDDING_API_KEY=
OPENAI_COMPATIBLE_EMBEDDING_MODEL=text-embedding-v4
OPENAI_COMPATIBLE_EMBEDDING_DIMENSIONS=1024

# Optional Java proxy. Use host.docker.internal:7890 when backend runs inside Docker Desktop.
BACKEND_JAVA_TOOL_OPTIONS=
