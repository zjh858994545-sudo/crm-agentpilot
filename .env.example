# Shared
APP_ENV=local

# Backend
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=local

# PostgreSQL + pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentpilot
POSTGRES_USER=agentpilot
POSTGRES_PASSWORD=agentpilot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Model provider, keep mock for local development and tests
AGENT_MODEL_PROVIDER=mock
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_CHAT_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_EMBEDDING_MODEL=
OPENAI_COMPATIBLE_TEMPERATURE=0.2
